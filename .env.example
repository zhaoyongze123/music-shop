# .env.example - 环境变量示例
# 复制为 .env 并填入实际值
# cp .env.example .env

# ===========================================
# Flask 应用配置
# ===========================================

# Flask 密钥（生产环境必须使用强随机密钥）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# 运行模式 (development / production)
FLASK_ENV=production

# ===========================================
# PostgreSQL 数据库配置
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=musicdb

# 数据库连接 URL（可选，直接用上面的配置）
# DATABASE_URL=postgresql://postgres:password@db:5432/musicdb

# ===========================================
# GitHub OAuth 登录配置
# ===========================================
# 从 https://github.com/settings/developers 获取
# 应用回调 URL: http://你的域名/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===========================================
# Dify RAG 知识库聊天机器人配置
# ===========================================
# Dify API 地址（如果 Dify 在同一服务器）
DIFIFY_API_URL=http://dify-proxy:80

# Dify API Key（在 Dify 控制台 → 设置 → API Key）
DIFIFY_API_KEY=your-dify-api-key-here

# ===========================================
# 阿里云 OSS（可选，用于存储静态文件）
# ===========================================
# ALIYUN_OSS_ACCESS_KEY_ID=your-access-key
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-secret-key
# ALIYUN_OSS_BUCKET=your-bucket-name
# ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
